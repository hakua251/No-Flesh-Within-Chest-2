			}]
			title: "大世界计算机"
			x: 3.0d
			y: 0.0d
		}
		{
			dependencies: ["2650CE0D76584853"]
			description: [
				"为了制造后续所需的纸和乙醇，一个甘蔗农场是必须的。"
				""
				"您可以使用任何方式来构造这个农场，其不需要有过大的规模。"
			]
			id: "4C734EDC56B5A572"
			rewards: [{
