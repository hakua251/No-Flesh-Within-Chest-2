	quests: [
		{
			description: [
				"您似乎也察觉到了——这些工具本身具有一些极其特殊的地方。"
				""
				"虽然没有任何证据，但是有一种可能情况，或者称为预感，在经过数百次的扫描后变得愈加强烈。"
				""
				"即，这种工匠技艺是由某个人或者某种存在创造出来并且留存于此的，但其目的目前尚未可知。"
				""
				"考虑到这些工具是十分有效且强大的，或许我们需要更多的去了解这样技艺，以解明这条传闻。"
			]
			icon: {
				Count: 1
				id: "tconstruct:pick_head"
				tag: {
					Material: "tconstruct:flint"
				}
			}
			id: "428D9599A58515E7"
			invisible: true
			rewards: [{
				id: "7FDB06D02D4ADB33"
				item: "lightmanscurrency:coin_iron"
				type: "item"
			}]
			subtitle: "灵光一现筑传闻"
			tasks: [{
				icon: {
