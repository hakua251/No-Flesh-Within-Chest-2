		}
		{
			dependencies: ["3D02CAC6C9FF9512"]
			description: [
				"为了发展机械，我们需要足够多的安山岩来大量制作安山合金。"
				""
				"因此我强烈建议您把安山岩提升到与锌矿同等重要的地位上，且&6其需求量可能比锌矿要大的多&r。"
			]
			id: "7FAD357E92A68A9D"
			rewards: [{
				id: "6367F8E05389C050"
